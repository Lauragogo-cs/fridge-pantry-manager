JWT_SECRET="change-this-secret-in-production-please"
PORT=4000

# Web Push (expiry reminder notifications). Generate your own keypair with:
#   npx web-push generate-vapid-keys
# and paste the values below. If left unset, push notifications are
# silently disabled and the rest of the app works normally.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:you@example.com"
